# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Google Drive Sync ──────────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com
# 2. Crie um projeto > Ative "Google Drive API"
# 3. Crie uma Service Account > Baixe o JSON de credenciais
# 4. Compartilhe a pasta do Drive com o e-mail da service account
# 5. Cole os valores abaixo

GOOGLE_SERVICE_ACCOUNT_EMAIL=lab-sync@seu-projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ID da pasta raiz do Lab no Google Drive
# (abra a pasta no Drive, copie o ID da URL: drive.google.com/drive/folders/ESSE_ID_AQUI)
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Secret para autenticar o Vercel Cron Job (gere qualquer string aleatória)
CRON_SECRET=uma-string-secreta-qualquer-aqui

# ── RegulAI — Copiloto ANVISA & P&D ───────────────────────────────────────────
# Provider primário: Groq (gratuito, 1.000 chamadas/dia, super rápido)
# Pegar em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Provider de fallback: OpenRouter (gratuito, modelos :free)
# Pegar em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
